SMARTSHEET_TOKEN=your_smartsheet_api_token
SHEET_ID=your_default_sheet_id

# LLM Providers — set any/all keys you want to use
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GOOGLE_API_KEY=AIza...
GROQ_API_KEY=gsk_...
MISTRAL_API_KEY=...
DEEPSEEK_API_KEY=sk-...
OPENROUTER_API_KEY=sk-or-...

# Optional: Smartsheet OAuth (authorization code flow via extension + /exchange on server).
# Register the Chrome redirect URL in Smartsheet Developer Tools, e.g.
#   https://YOUR_EXTENSION_ID.chromiumapp.org/
SMARTSHEET_OAUTH_CLIENT_ID=
SMARTSHEET_OAUTH_CLIENT_SECRET=
# SMARTSHEET_OAUTH_SCOPES=READ_SHEETS WRITE_SHEETS

# In-app bug reports
# - GET /api/bug-reports and /status admin routes are DISABLED unless this is set.
# - Pick a long random secret (e.g. `python -c "import secrets;print(secrets.token_urlsafe(32))"`).
# - JSONL mirror path is optional; defaults to data/bug_reports.jsonl.
BUG_REPORTS_ADMIN_TOKEN=
# BUG_REPORTS_JSONL_PATH=data/bug_reports.jsonl
