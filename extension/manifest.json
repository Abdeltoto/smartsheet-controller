{
  "manifest_version": 3,
  "name": "Smartsheet Controller",
  "version": "1.2.0",
  "description": "Side panel chat for Smartsheet: detects the active sheet from the URL and opens your Controller next to your work.",
  "minimum_chrome_version": "114",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "permissions": ["storage", "sidePanel", "tabs", "identity"],
  "host_permissions": [
    "https://app.smartsheet.com/*",
    "http://127.0.0.1:8100/*",
    "http://localhost:8100/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Smartsheet Controller — side panel",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "content_scripts": [
    {
      "matches": ["http://127.0.0.1:8100/*", "http://localhost:8100/*"],
      "js": ["content/embed.js"],
      "run_at": "document_start",
      "all_frames": true
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["content/embed.css"],
      "matches": ["http://127.0.0.1:8100/*", "http://localhost:8100/*"]
    }
  ],
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Ctrl+Shift+Y",
        "mac": "Command+Shift+Y"
      },
      "description": "Open Smartsheet Controller side panel"
    }
  }
}
